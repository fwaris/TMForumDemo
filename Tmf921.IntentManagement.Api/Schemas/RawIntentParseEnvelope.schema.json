{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/tmf921/raw-intent-parse-envelope.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "parsed",
        "clarification_required"
      ]
    },
    "semanticCore": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "targets",
        "expectations"
      ],
      "properties": {
        "intentName": {
          "type": [
            "string",
            "null"
          ]
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "targets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/target"
          }
        },
        "expectations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/expectation"
          }
        },
        "context": {
          "type": [
            "string",
            "null"
          ]
        },
        "priority": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/diagnostic"
      }
    }
  },
  "$defs": {
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": [],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [],
      "properties": {
        "id": {
          "type": [
            "string",
            "null"
          ]
        },
        "targetType": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "quantity": {
      "type": "object",
      "additionalProperties": false,
      "required": [],
      "properties": {
        "value": {
          "type": [
            "string",
            "null"
          ]
        },
        "unit": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "functionApplication": {
      "type": "object",
      "additionalProperties": false,
      "required": [],
      "properties": {
        "name": {
          "type": [
            "string",
            "null"
          ]
        },
        "arguments": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "children"
      ],
      "properties": {
        "kind": {
          "type": [
            "string",
            "null"
          ]
        },
        "subject": {
          "type": [
            "string",
            "null"
          ]
        },
        "operator": {
          "type": [
            "string",
            "null"
          ]
        },
        "value": {
          "type": [
            "string",
            "null"
          ]
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/conditionClause"
          }
        }
      }
    },
    "conditionClause": {
      "type": "object",
      "additionalProperties": false,
      "required": [],
      "properties": {
        "kind": {
          "type": [
            "string",
            "null"
          ]
        },
        "subject": {
          "type": [
            "string",
            "null"
          ]
        },
        "operator": {
          "type": [
            "string",
            "null"
          ]
        },
        "value": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "expectation": {
      "type": "object",
      "additionalProperties": false,
      "required": [],
      "properties": {
        "kind": {
          "type": [
            "string",
            "null"
          ]
        },
        "subject": {
          "type": [
            "string",
            "null"
          ]
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "condition": {
          "anyOf": [
            {
              "$ref": "#/$defs/condition"
            },
            {
              "type": "null"
            }
          ]
        },
        "quantity": {
          "anyOf": [
            {
              "$ref": "#/$defs/quantity"
            },
            {
              "type": "null"
            }
          ]
        },
        "functionApplication": {
          "anyOf": [
            {
              "$ref": "#/$defs/functionApplication"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  }
}
