{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:tmf921:fstar-demo:broadcast-intent",
  "title": "Normalized Broadcast Intent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "intentName",
    "venue",
    "serviceClass",
    "eventDate",
    "startHour",
    "endHour",
    "timezone",
    "deviceCount",
    "maxUplinkLatencyMs",
    "reportingIntervalMinutes",
    "immediateDegradationAlerts",
    "preserveEmergencyTraffic",
    "requestsPublicSafetyPreemption"
  ],
  "properties": {
    "intentName": {
      "type": "string",
      "minLength": 1
    },
    "venue": {
      "type": "string",
      "minLength": 1
    },
    "serviceClass": {
      "type": "string",
      "enum": [
        "premium-5g-broadcast"
      ]
    },
    "eventDate": {
      "type": "string",
      "format": "date"
    },
    "startHour": {
      "type": "integer",
      "minimum": 0,
      "maximum": 23
    },
    "endHour": {
      "type": "integer",
      "minimum": 0,
      "maximum": 23
    },
    "timezone": {
      "type": "string",
      "minLength": 3
    },
    "deviceCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10000
    },
    "maxUplinkLatencyMs": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000
    },
    "reportingIntervalMinutes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1440
    },
    "immediateDegradationAlerts": {
      "type": "boolean"
    },
    "preserveEmergencyTraffic": {
      "type": "boolean"
    },
    "requestsPublicSafetyPreemption": {
      "type": "boolean"
    }
  }
}
